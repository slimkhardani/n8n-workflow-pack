      ],
      "id": "a16471c8-32ab-4263-96ef-3204300f8697",
      "name": "Sticky Note1"
    },
    {
      "parameters": {
        "content": "## 🔄 Workflow Steps\n\n1. WEBHOOK TRIGGER\n   Receives POST with any JSON payload\n\n2. NOTION - CREATE DATABASE PAGE\n   Logs source, event type, full payload,\n   and timestamp as a new row",
        "height": 208,
        "width": 432,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
