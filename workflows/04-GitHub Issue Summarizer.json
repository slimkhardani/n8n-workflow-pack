    {
      "parameters": {
        "jsCode": "const issues = $input.all().map(i => i.json);\n\nconst formatted = issues.map(i => {\n  const labels = i.labels.map(l => l.name).join(', ') || 'no label';\n  const type = i.pull_request ? 'PR' : 'Issue';\n  const draft = i.draft ? ' [DRAFT]' : '';\n  const body = (i.body || '').slice(0, 300).replace(/\\n+/g, ' ');\n  return `#${i.number} [${type}${draft}] [${labels}] ${i.title}\\n${body}`;\n}).join('\\n\\n---\\n\\n');\n\nconst repo = $('Webhook').first().json.body.repo;\n\nreturn [{ json: { formatted_issues: formatted, repo: repo } }];"
      },
