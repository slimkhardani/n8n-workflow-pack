    {
      "parameters": {
        "content": "## ⚙️ Setup Required\n\n1. Gemini API Key\n   → aistudio.google.com\n   → Free tier is enough\n\n2. Gmail OAuth2\n   → Connect your Google account\n   → Allow n8n permissions\n\n3. Google Sheets OAuth2\n   → Same Google account\n   → Create a sheet called \"LinkedIn Posts\"\n   → Columns: Date, Topic, Post, Status",
        "height": 320,
        "width": 496,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
